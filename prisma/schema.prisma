// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Etapas de edad del bebé
model AgeStage {
  id          String   @id @default(cuid())
  name        String   // "6-8 meses", "8-10 meses", "10-12 meses"
  minMonths   Int      // 6, 8, 10
  maxMonths   Int      // 8, 10, 12
  description String?  // Descripción de la etapa
  recipes     Recipe[]
  ingredients Ingredient[]
  introSteps  IntroStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Categorías de alimentos
model FoodCategory {
  id          String       @id @default(cuid())
  name        String       // "Frutas", "Verduras", "Proteínas", "Cereales", "Lácteos"
  description String?
  icon        String?      // Emoji o nombre de icono
  color       String?      // Color para la UI
  ingredients Ingredient[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Ingrediente individual
model Ingredient {
  id              String          @id @default(cuid())
  name            String          // Nombre del ingrediente
  categoryId      String
  category        FoodCategory    @relation(fields: [categoryId], references: [id])
  isAllergen      Boolean         @default(false) // Si es un alérgeno común
  minAgeMonths    Int             @default(6) // Edad mínima recomendada
  description     String?
  nutritionalInfo String?         // Información nutricional
  introWeek       Int?            // Semana recomendada de introducción (1, 2, 3...)
  introOrder      Int?            // Orden dentro de la semana
  ageStageId      String?
  ageStage        AgeStage?       @relation(fields: [ageStageId], references: [id])
  recipeIngredients RecipeIngredient[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// Receta
model Recipe {
  id                String             @id @default(cuid())
  name              String             // Nombre de la receta
  description       String?            // Descripción corta
  ageStageId        String
  ageStage          AgeStage           @relation(fields: [ageStageId], references: [id])
  minAgeMonths      Int                // Edad mínima en meses
  prepTime          Int                // Tiempo de preparación en minutos
  cookTime          Int                // Tiempo de cocción en minutos
  servings          Int                @default(1) // Número de porciones
  instructions      String             // JSON string con los pasos
  tips              String?            // JSON string con consejos opcionales
  nutritionalValue  String?            // Información nutricional
  imageUrl          String?            // URL de imagen
  mealType          String?            // "desayuno", "almuerzo", "merienda", "cena"
  ingredients       RecipeIngredient[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// Relación Receta-Ingrediente
model RecipeIngredient {
  id         String   @id @default(cuid())
  recipeId   String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  quantity   String   // "100g", "2 cucharadas", "1 unidad"
  unit       String?  // "g", "cucharadas", "unidades"
  notes      String?  // Notas adicionales
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([recipeId, ingredientId])
}

// Guía de introducción - Pasos semanales
model IntroStep {
  id              String    @id @default(cuid())
  weekNumber      Int       // Semana 1, 2, 3, 4...
  dayNumber       Int       // Día dentro de la semana (1-7)
  title           String    // Título del paso
  description     String    // Descripción detallada
  foodGroup       String?   // Grupo de alimentos (verduras, frutas, cereales, proteínas)
  specificFood    String?   // Alimento específico a introducir
  portionSize     String?   // Tamaño de porción recomendado
  frequency       String?   // Frecuencia de comida
  breastmilkNote  String?   // Nota sobre lactancia materna
  tips            String?   // Consejos adicionales (JSON)
  warnings        String?   // Advertencias (JSON)
  ageStageId      String
  ageStage        AgeStage  @relation(fields: [ageStageId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Información sobre lactancia
model BreastfeedingGuide {
  id              String   @id @default(cuid())
  ageMonths       Int      // Edad en meses
  title           String   // Título de la guía
  description     String   // Descripción
  frequency       String   // Frecuencia recomendada
  amount          String?  // Cantidad aproximada
  tips            String?  // Consejos (JSON)
  importantNotes  String?  // Notas importantes (JSON)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Reacción del bebé a un alimento
model BabyReaction {
  id              String   @id @default(cuid())
  introStepId     String   // Referencia al paso de introducción
  foodName        String   // Nombre del alimento
  reaction        String   // "liked", "neutral", "disliked", "allergic"
  notes           String?  // Comentarios adicionales del padre
  includeInDiet   Boolean  @default(true) // Si debe incluirse en futuras comidas
  reactionDate    DateTime @default(now()) // Fecha de la reacción
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([introStepId, foodName]) // Una reacción por alimento por paso
}
